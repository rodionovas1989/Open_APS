# ===========================================
# Конфигурация базы данных APS
# ===========================================

# Тип БД: sqlite, postgresql, mysql
DB_TYPE=sqlite

# Для SQLite
SQLITE_DB_PATH=aps_database.db

# Для PostgreSQL (раскомментировать при использовании)
# DB_TYPE=postgresql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=aps_db
# DB_USER=postgres
# DB_PASSWORD=postgres

# Для MySQL (раскомментировать при использовании)
# DB_TYPE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=aps_db
# DB_USER=root
# DB_PASSWORD=mysql
